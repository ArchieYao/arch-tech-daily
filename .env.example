# 管理后台默认管理员（可选，不设则为 archie / admin123）
# ADMIN_USERNAME=archie
# ADMIN_PASSWORD=admin123

# API Key 加密密钥（建议设置随机字符串，不设则使用默认值）
CONFIG_SECRET=your-random-secret-here

# 服务端口
PORT=3456

# we-mp-rss 服务（微信公众号 RSS），Docker 内使用 http://we-mp-rss:8001
WERSS_BASE_URL=http://we-mp-rss:8001
# we-mp-rss 登录账号（默认 admin/admin）
WERSS_USERNAME=admin
WERSS_PASSWORD=admin
