# ============================================================
# AI Daily 环境变量配置
# 复制本文件为 .env 并按需修改
# ============================================================

# ---------- 管理后台登录账号 ----------
# 首次启动时会自动创建管理员账号（默认 admin / admin123）
# 建议部署后立即在后台修改密码
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# ---------- API Key 加密密钥 ----------
# 用于加密存储你的 AI API Key（AES-256-GCM）
# 【重要】请替换为随机字符串！不设置则使用内置默认值，安全性较低
# 可用命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CONFIG_SECRET=your-random-secret-here

# ---------- 服务端口 ----------
PORT=3456

# ---------- 时区 ----------
TZ=Asia/Shanghai

# ---------- we-mp-rss 微信公众号 RSS 服务 ----------
# Docker Compose 部署时使用容器名访问
WERSS_BASE_URL=http://we-mp-rss:8001
# we-mp-rss 服务的登录账号（默认值，一般无需修改）
WERSS_USERNAME=admin
WERSS_PASSWORD=admin@123

# ---------- 翻译功能（可选）----------
# 设为 true 启用文章全文翻译能力（需要额外 API 调用）
# ENABLE_TRANSLATION=false
